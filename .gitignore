# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore sensitive tfvars only
*secrets*.tfvars
*secrets*.tfvars.json

# Ignore override and plan files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.tfplan

# Ignore lock info, CLI config
.terraform.tfstate.lock.info
.terraformrc
terraform.rc